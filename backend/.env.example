# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Google Ads API (apply at ads.google.com/home/tools/manager-accounts/)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Groq API (get from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Database — use the docker-compose values for local dev
DATABASE_URL=postgresql+asyncpg://adcoherence:adcoherence@localhost:5432/adcoherence
SUPABASE_URL=
SUPABASE_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here
